{
  "name": "offline-quilt-solver",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare-assets": "node scripts/copy-z3-assets.mjs",
    "predev": "npm run prepare-assets",
    "dev": "vite",
    "dev:https": "node scripts/create-local-cert.mjs && vite --host 0.0.0.0",
    "prebuild": "npm run prepare-assets",
    "build": "tsc --noEmit && vite build && node scripts/generate-service-worker.mjs",
    "preview": "vite preview",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:offline": "npm run build && node scripts/verify-offline.mjs",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.61.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "coi-serviceworker": "^0.1.7",
    "z3-solver": "^4.16.0"
  }
}
